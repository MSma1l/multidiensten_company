# --- PostgreSQL ---
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=appdb
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Admin panel access ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
ADMIN_PATH=your-secret-admin-path

# --- JWT ---
JWT_SECRET=generate-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- CORS (frontend origins allowed to call the API) ---
# In production set this to your HTTPS domain, e.g. https://yourdomain.com
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# --- Production deployment (reverse proxy + HTTPS) ---
# Public domain served by the nginx proxy. Used to render the proxy config and
# as the certbot certificate name. Example: yourdomain.com
SERVER_NAME=yourdomain.com
# Email for Let's Encrypt expiry notices (used by deploy/init-letsencrypt.sh).
CERTBOT_EMAIL=you@example.com
